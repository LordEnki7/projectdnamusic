# ─── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Neon:      postgres://user:pass@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require
# Hostinger: postgres://user:pass@hostname:5432/dbname
DATABASE_URL=

# Random secret used to sign sessions (run: openssl rand -hex 32)
SESSION_SECRET=

# Your production domain — used in email links
APP_URL=https://projectdnamusic.info

# ─── Stripe ───────────────────────────────────────────────────────────────────

# Live secret key  (sk_live_...)
STRIPE_SECRET_KEY=

# Webhook signing secret from the Stripe dashboard
STRIPE_WEBHOOK_SECRET=

# Live publishable key  (pk_live_...)
VITE_STRIPE_PUBLIC_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────────────

# Get from https://resend.com/api-keys
RESEND_API_KEY=

# The "From" address (must be a verified domain in Resend)
RESEND_FROM_EMAIL=noreply@projectdnamusic.info

# ─── AI (OpenAI) ──────────────────────────────────────────────────────────────

# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Media Storage ────────────────────────────────────────────────────────────

# Absolute path on the host where audio/image files are stored.
# The Docker volume mounts here automatically when using docker-compose.
LOCAL_STORAGE_PATH=/app/uploads

# ─── Optional ─────────────────────────────────────────────────────────────────

# Port the server listens on (default: 5000)
PORT=5000

# Test keys (only needed if using Stripe test mode)
# STRIPE_TEST_SECRET_KEY=sk_test_...
# VITE_STRIPE_TEST_PUBLIC_KEY=pk_test_...
